#!/system/bin/sh
# ─────────────────────────────────────────────────────────────
#  Thermal Toggle — powered by Pyrox Thermal v3.0 logic
#  Integrates freeze/kill thermal services into DAVION ENGINE
#  Usage: thermal_toggle enable | disable
# ─────────────────────────────────────────────────────────────

MOD_DIR="/data/adb/modules/GovThermal"
BB="$MOD_DIR/busybox"
CFG_DIR="/sdcard/GovThermal/config"
LOG="$MOD_DIR/service.log"
THERMAL_STATE_FILE="$CFG_DIR/thermal_state"

ACTION="$1"   # "enable" = thermal ON (restored), "disable" = thermal OFF (frozen)

log_msg() {
    echo "[$(date '+%H:%M:%S')] [THERMAL] $1" >> "$LOG"
}

# ── Busybox wrappers ─────────────────────────────────────────
[ -x "$BB" ] || BB=""
_bb() { [ -n "$BB" ] && "$BB" "$@" || "$@"; }

# ── lock_val: write then lock file permissions ───────────────
lock_val() {
    for p in $2; do
        [ ! -f "$p" ] && continue
        chown root:root "$p"   2>/dev/null
        chmod 644 "$p"         2>/dev/null
        echo "$1" > "$p"
        chmod 444 "$p"         2>/dev/null
    done
}

# ── list_thermal_services ────────────────────────────────────
# Combines a hardcoded safe-to-stop list (from real device observation)
# with a dynamic scan of init rc files.
# Safe = these are throttle/policy daemons, NOT kernel drivers.
list_thermal_services() {
    # Hardcoded: known thermal daemons seen on MTK/Dimensity devices
    # These are safe to stop for gaming — they are userspace throttle agents
    cat <<'EOF'
thermal
thermald
thermal_core
thermal_manager
thermalloadalgod
vendor.thermal-hal-2-0.mtk
vendor.thermal-hal-2-0
vendor.thermal-hal-1-0
thermal-engine
mi_thermald
mtktsmonitor
EOF
    # Dynamic scan: pick up any additional device-specific thermal services
    for rc in $(find /system/etc/init /vendor/etc/init /odm/etc/init /system_ext/etc/init -type f 2>/dev/null); do
        grep "^service" "$rc" 2>/dev/null | awk '{print $2}'
    done | grep -i thermal
}

# ════════════════════════════════════════════════════════════
#  DISABLE THERMAL  (pyrox freeze logic)
# ════════════════════════════════════════════════════════════
disable_thermal() {
    log_msg "Disabling thermal — stopping userspace thermal services..."

    # 1. Explicit stop of all known thermal services (deduplicated)
    for svc in $(list_thermal_services | sort -u); do
        # Try stopping twice — some services respawn once on first stop
        stop  "$svc" 2>/dev/null
        sleep 0.3
        stop  "$svc" 2>/dev/null
        log_msg "Stopped service: $svc"
    done

    # 2. Also stop via setprop ctl (catches HAL services not responding to stop)
    for svc in thermald vendor.thermal-hal-2-0.mtk vendor.thermal-hal-2-0 thermal thermal_core thermal_manager thermalloadalgod; do
        setprop ctl.stop "$svc" 2>/dev/null
    done

    # 3. Mark thermal engine disabled via persist prop (survives across soft restarts)
    resetprop persist.vendor.thermal.engine.disable 1 2>/dev/null
    resetprop persist.sys.thermal.enable 0            2>/dev/null

    # 4. Freeze ALL thermal PIDs (SIGSTOP — safe, reversible)
    for pid in $(_bb pgrep -f thermal 2>/dev/null); do
        [ "$pid" = "$$" ] && continue   # never freeze self
        kill -SIGSTOP "$pid" 2>/dev/null
        log_msg "Frozen PID $pid"
    done

    # 5. Freeze thermal props (resetprop marks them as freezed)
    for prop in $(resetprop 2>/dev/null | grep -i 'thermal.*running' | awk -F'[][]' '{print $2}'); do
        resetprop "$prop" freezed 2>/dev/null
        log_msg "Froze prop: $prop"
    done

    # 4. MTK driver thermal zones (raise to 125 °C, remove coolers)
    if [ -f /proc/driver/thermal/tzcpu ]; then
        t_limit="125"
        no_cooler="0 0 no-cooler 0 0 no-cooler 0 0 no-cooler 0 0 no-cooler 0 0 no-cooler 0 0 no-cooler 0 0 no-cooler 0 0 no-cooler 0 0 no-cooler"
        lock_val "1 ${t_limit}000 0 mtktscpu-sysrst $no_cooler 200"    /proc/driver/thermal/tzcpu
        lock_val "1 ${t_limit}000 0 mtktspmic-sysrst $no_cooler 1000"  /proc/driver/thermal/tzpmic
        lock_val "1 ${t_limit}000 0 mtktsbattery-sysrst $no_cooler 1000" /proc/driver/thermal/tzbattery
        lock_val "1 ${t_limit}000 0 mtk-cl-kshutdown00 $no_cooler 2000" /proc/driver/thermal/tzpa
        lock_val "1 ${t_limit}000 0 mtktscharger-sysrst $no_cooler 2000" /proc/driver/thermal/tzcharger
        lock_val "1 ${t_limit}000 0 mtktswmt-sysrst $no_cooler 1000"   /proc/driver/thermal/tzwmt
        lock_val "1 ${t_limit}000 0 mtktsAP-sysrst $no_cooler 1000"    /proc/driver/thermal/tzbts
        lock_val "1 ${t_limit}000 0 mtk-cl-kshutdown01 $no_cooler 1000" /proc/driver/thermal/tzbtsnrpa
        lock_val "1 ${t_limit}000 0 mtk-cl-kshutdown02 $no_cooler 1000" /proc/driver/thermal/tzbtspa
        log_msg "MTK driver thermal limits raised to 125°C"
    fi

    # 5. Disable sysfs thermal zones
    for zone in /sys/class/thermal/thermal_zone*; do
        lock_val "disabled" "$zone/mode"
    done

    # 6. Remove CPU thermal message limits
    if [ -f /sys/devices/virtual/thermal/thermal_message/cpu_limits ]; then
        for i in 0 2 4 6 7; do
            maxfreq="$(cat /sys/devices/system/cpu/cpu$i/cpufreq/cpuinfo_max_freq 2>/dev/null)"
            [ -n "$maxfreq" ] && [ "$maxfreq" -gt 0 ] && \
                lock_val "cpu$i $maxfreq" /sys/devices/virtual/thermal/thermal_message/cpu_limits
        done
        log_msg "CPU thermal message limits removed"
    fi

    # 7. Disable PPM thermal/power-throttle policies
    if [ -d /proc/ppm ]; then
        for idx in $(awk -F'[][]' '/PWR_THRO|THERMAL/{print $2}' /proc/ppm/policy_status 2>/dev/null); do
            lock_val "$idx 0" /proc/ppm/policy_status
        done
        log_msg "PPM thermal policies disabled"
    fi

    # 8. GPU power limits
    if [ -f /proc/gpufreq/gpufreq_power_limited ]; then
        lock_val "ignore_batt_oc 1"          /proc/gpufreq/gpufreq_power_limited
        lock_val "ignore_batt_percent 1"     /proc/gpufreq/gpufreq_power_limited
        lock_val "ignore_low_batt 1"         /proc/gpufreq/gpufreq_power_limited
        lock_val "ignore_thermal_protect 1"  /proc/gpufreq/gpufreq_power_limited
        lock_val "ignore_pbm_limited 1"      /proc/gpufreq/gpufreq_power_limited
        log_msg "GPU power limits bypassed"
    fi

    # 9. Disable thm_enable + lock virtual thermal dir
    lock_val 0 /sys/class/thermal/thermal_zone0/thm_enable
    find /sys/devices/virtual/thermal -exec chmod 000 {} + 2>/dev/null

    # 10. Mali GPU thermal
    chmod 000 /sys/devices/*.mali/tmu          2>/dev/null
    chmod 000 /sys/devices/*.mali/throttling1  2>/dev/null
    chmod 000 /sys/devices/*.mali/throttling2  2>/dev/null
    chmod 000 /sys/devices/*.mali/throttling3  2>/dev/null
    chmod 000 /sys/devices/*.mali/throttling4  2>/dev/null
    chmod 000 /sys/devices/*.mali/tripping     2>/dev/null

    # 11. Qualcomm / generic MSM thermal
    lock_val 0 /sys/kernel/msm_thermal/enabled
    lock_val 0 /sys/class/kgsl/kgsl-3d0/throttling
    lock_val N /sys/module/msm_thermal/parameters/enabled

    # 12. Battery OC throttle (MTK)
    lock_val "stop 1" /proc/mtk_batoc_throttling/battery_oc_protect_stop

    # 13. Override Android thermalservice
    cmd thermalservice override-status 0 2>/dev/null

    # 14. Disable FPSGO thermal
    lock_val 0 /sys/kernel/fpsgo/fbt/thrm_enable     2>/dev/null
    lock_val 0 /sys/kernel/fpsgo/fbt/thrm_limit_cpu  2>/dev/null

    # 15. GPT thermal
    [ -f /sys/kernel/thermal/gpt ] && echo disable > /sys/kernel/thermal/gpt 2>/dev/null

    mkdir -p "$CFG_DIR"
    echo "disabled" > "$THERMAL_STATE_FILE"
    log_msg "Thermal DISABLED ✓"
}

# ════════════════════════════════════════════════════════════
#  ENABLE THERMAL  (restore sane defaults)
# ════════════════════════════════════════════════════════════
enable_thermal() {
    log_msg "Re-enabling thermal services..."

    # 1. Thaw ALL frozen thermal PIDs first
    for pid in $(_bb pgrep -f thermal 2>/dev/null); do
        kill -SIGCONT "$pid" 2>/dev/null
        log_msg "Thawed PID $pid"
    done

    # 2. Clear persist disable props
    resetprop persist.vendor.thermal.engine.disable 0 2>/dev/null
    resetprop persist.sys.thermal.enable 1            2>/dev/null

    # 3. Restore virtual thermal dir permissions
    find /sys/devices/virtual/thermal -exec chmod 644 {} + 2>/dev/null
    find /sys/devices/virtual/thermal -type d -exec chmod 755 {} + 2>/dev/null

    # 4. Restore Mali GPU thermal
    chmod 644 /sys/devices/*.mali/tmu          2>/dev/null
    chmod 644 /sys/devices/*.mali/throttling1  2>/dev/null
    chmod 644 /sys/devices/*.mali/throttling2  2>/dev/null
    chmod 644 /sys/devices/*.mali/throttling3  2>/dev/null
    chmod 644 /sys/devices/*.mali/throttling4  2>/dev/null
    chmod 644 /sys/devices/*.mali/tripping     2>/dev/null

    # 5. Re-enable sysfs thermal zones
    for zone in /sys/class/thermal/thermal_zone*; do
        [ -f "$zone/mode" ] && chmod 644 "$zone/mode" && echo "enabled" > "$zone/mode" 2>/dev/null
    done

    # 6. Restore MSM thermal
    chmod 644 /sys/kernel/msm_thermal/enabled 2>/dev/null
    echo 1 > /sys/kernel/msm_thermal/enabled  2>/dev/null
    echo Y > /sys/module/msm_thermal/parameters/enabled 2>/dev/null

    # 7. Restart all thermal services (hardcoded + dynamic)
    for svc in $(list_thermal_services | sort -u); do
        start "$svc" 2>/dev/null
        log_msg "Restarted service: $svc"
    done

    # 8. Also restart via setprop ctl
    for svc in thermald vendor.thermal-hal-2-0.mtk vendor.thermal-hal-2-0 thermal thermal_core thermal_manager thermalloadalgod; do
        setprop ctl.start "$svc" 2>/dev/null
    done

    # 9. Restore Android thermalservice
    cmd thermalservice override-status 1 2>/dev/null

    # 10. Re-enable FPSGO thermal
    chmod 644 /sys/kernel/fpsgo/fbt/thrm_enable 2>/dev/null
    echo 1 > /sys/kernel/fpsgo/fbt/thrm_enable  2>/dev/null

    # 11. GPT thermal restore
    [ -f /sys/kernel/thermal/gpt ] && echo enable > /sys/kernel/thermal/gpt 2>/dev/null

    mkdir -p "$CFG_DIR"
    echo "enabled" > "$THERMAL_STATE_FILE"
    log_msg "Thermal ENABLED ✓"
}

# ── Dispatch ─────────────────────────────────────────────────
case "$ACTION" in
    disable) disable_thermal ;;
    enable)  enable_thermal  ;;
    *)
        echo "Usage: thermal_toggle [enable|disable]" >&2
        exit 1
        ;;
esac
