#!/system/bin/sh
### ==== FLOOD GUARD BEGIN ==== ###
SCRIPT_NAME="$(basename "$0")"
STATE_DIR="/data/adb/modules/GovThermal/.guard"
mkdir -p "$STATE_DIR"
RUN_TS_FILE="$STATE_DIR/${SCRIPT_NAME}.last"
COUNT_FILE="$STATE_DIR/${SCRIPT_NAME}.count"
NOW=$(date +%s)
LAST=$(cat "$RUN_TS_FILE" 2>/dev/null || echo 0)
COUNT=$(cat "$COUNT_FILE" 2>/dev/null || echo 0)
MIN_INTERVAL=5; MAX_RUNS=5; WINDOW=60
[ $((NOW - LAST)) -lt $MIN_INTERVAL ] && exit 0
if [ $((NOW - LAST)) -lt $WINDOW ]; then COUNT=$((COUNT + 1)); else COUNT=1; fi
if [ "$COUNT" -gt "$MAX_RUNS" ]; then
  echo "[FLOOD-GUARD] $SCRIPT_NAME blocked" >> /sdcard/DAVION_ENGINE/flood_guard.log
  exit 0
fi
echo "$NOW" > "$RUN_TS_FILE"
echo "$COUNT" > "$COUNT_FILE"
### ==== FLOOD GUARD END ==== ###

# -------------------------
# TRIM MEMORY v2 — DAVION ENGINE
# Optimized: rate-limited, skip foreground/system apps
# -------------------------
LOG_FILE="/sdcard/DAVION_ENGINE/DAVION_ENGINE.log"

log_msg() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

# 1. fstrim on /data (only if fstrim exists and last trim was >6h ago)
TRIM_TS_FILE="/data/adb/modules/GovThermal/.guard/last_fstrim"
TRIM_INTERVAL=21600  # 6 hours
LAST_TRIM=$(cat "$TRIM_TS_FILE" 2>/dev/null || echo 0)
NOW=$(date +%s)
if [ $((NOW - LAST_TRIM)) -ge "$TRIM_INTERVAL" ]; then
    if [ -x /system/bin/fstrim ]; then
        log_msg "Starting fstrim on /data"
        /system/bin/fstrim -v /data 2>&1 | while IFS= read -r line; do
            log_msg "fstrim: $line"
        done
        echo "$NOW" > "$TRIM_TS_FILE"
    else
        log_msg "WARNING: fstrim not found — skipping storage TRIM"
    fi
fi

# 2. Detect foreground app (do NOT trim it)
FOREGROUND_PKG=$(dumpsys activity 2>/dev/null | grep -m1 'mResumedActivity' | \
    grep -oE '[a-z][a-zA-Z0-9_]*\.[a-zA-Z0-9_.]+' | head -n1)

# 3. Trim only third-party apps in background (not foreground, not system)
log_msg "Sending trim memory signals to background apps"
TRIM_COUNT=0
for pkg in $(pm list packages -3 2>/dev/null | cut -f2 -d:); do
    case "$pkg" in
        com.android.systemui|com.android.launcher*|"$FOREGROUND_PKG") continue ;;
    esac
    # Only trim if the app is actually running
    if am force-stop --check "$pkg" 2>/dev/null | grep -q "running"; then
        am send-trim-memory "$pkg" RUNNING_MODERATE 2>/dev/null
        TRIM_COUNT=$((TRIM_COUNT + 1))
    fi
done

log_msg "Trim cycle completed — trimmed $TRIM_COUNT apps"
