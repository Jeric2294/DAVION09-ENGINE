# VM tuning — NOTE: swappiness min 10 to avoid OOM thrash
az_vm_performance() {
    echo 40  > /proc/sys/vm/vfs_cache_pressure 2>/dev/null
    echo 20  > /proc/sys/vm/dirty_ratio 2>/dev/null
    echo 8   > /proc/sys/vm/dirty_background_ratio 2>/dev/null
    echo 10  > /proc/sys/vm/swappiness 2>/dev/null   # never 0 — causes OOM on Android
    echo 200 > /proc/sys/vm/dirty_expire_centisecs 2>/dev/null
}

az_vm_balance() {
    echo 100  > /proc/sys/vm/vfs_cache_pressure 2>/dev/null
    echo 20   > /proc/sys/vm/dirty_ratio 2>/dev/null
    echo 10   > /proc/sys/vm/dirty_background_ratio 2>/dev/null
    echo 60   > /proc/sys/vm/swappiness 2>/dev/null
    echo 3000 > /proc/sys/vm/dirty_expire_centisecs 2>/dev/null
}

az_vm_powersave() {
    echo 120  > /proc/sys/vm/vfs_cache_pressure 2>/dev/null
    echo 30   > /proc/sys/vm/dirty_ratio 2>/dev/null
    echo 15   > /proc/sys/vm/dirty_background_ratio 2>/dev/null
    echo 100  > /proc/sys/vm/swappiness 2>/dev/null
    echo 1500 > /proc/sys/vm/dirty_expire_centisecs 2>/dev/null
}

# Battery saver module
az_battery_saver_enable() {
    if [ -f /sys/module/battery_saver/parameters/enabled ]; then
        if grep -qo '[0-9]\+' /sys/module/battery_saver/parameters/enabled 2>/dev/null; then
            az_write 1 /sys/module/battery_saver/parameters/enabled
        else
            az_write Y /sys/module/battery_saver/parameters/enabled
        fi
    fi
}

az_battery_saver_disable() {
    if [ -f /sys/module/battery_saver/parameters/enabled ]; then
        if grep -qo '[0-9]\+' /sys/module/battery_saver/parameters/enabled 2>/dev/null; then
            az_write 0 /sys/module/battery_saver/parameters/enabled
        else
            az_write N /sys/module/battery_saver/parameters/enabled
        fi
    fi
}

# ===========================================================================
# INIT
# ===========================================================================
azenith_init_cpu() {
    az_log "CPU init start"
    echo 500000  > /proc/sys/kernel/sched_migration_cost_ns 2>/dev/null
    echo 1000000 > /proc/sys/kernel/sched_min_granularity_ns 2>/dev/null
    echo 500000  > /proc/sys/kernel/sched_wakeup_granularity_ns 2>/dev/null
    echo 255     > /proc/sys/kernel/sched_lib_mask_force 2>/dev/null

    local CPU="/sys/devices/system/cpu/cpu0/cpufreq"
    chmod 644 "$CPU/scaling_governor" 2>/dev/null
    local default_gov
    default_gov=$(cat "$CPU/scaling_governor" 2>/dev/null || echo "schedutil")
    setprop persist.sys.mtkaieng.default_cpu_gov "$default_gov" 2>/dev/null
    az_log "Default governor: $default_gov"

    if [ "$default_gov" = "performance" ] && [ -z "$(getprop persist.sys.mtkaieng.custom_default_cpu_gov 2>/dev/null)" ]; then
        for gov in sugov_ext schedhorizon schedutil_plus uag schedplus ondemand schedutil interactive; do
            if grep -q "$gov" "$CPU/scaling_available_governors" 2>/dev/null; then
                setprop persist.sys.mtkaieng.default_cpu_gov "$gov" 2>/dev/null
                default_gov="$gov"
                az_log "Fallback governor: $gov"
                break
            fi
        done
    fi

    chmod 644 /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor 2>/dev/null
    echo "$default_gov" | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor > /dev/null 2>&1
    chmod 444 /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor 2>/dev/null

    local IO_DEV=""
    for blk in sda mmcblk0; do
        [ -f "/sys/block/$blk/queue/scheduler" ] && IO_DEV="$blk" && break
    done
    if [ -n "$IO_DEV" ]; then
        local default_io
        default_io=$(grep -o '\[.*\]' "/sys/block/$IO_DEV/queue/scheduler" 2>/dev/null | tr -d '[]')
        setprop persist.sys.mtkaieng.default_io "$default_io" 2>/dev/null
        az_log "Default I/O: $default_io"
    fi

    az_tune_schedutil balance
    az_vm_balance
    az_log "CPU init done"
}

# ===========================================================================
# PERFORMANCE PROFILE
# ===========================================================================
azenith_performance_cpu() {
    az_log "Profile: PERFORMANCE"

    local gov
    gov=$(getprop persist.sys.mtkaieng.custom_perf_cpu_gov 2>/dev/null)
    [ -z "$gov" ] && gov="performance"
    az_set_governor "$gov"

    local io
    io=$(getprop persist.sys.mtkaieng.custom_perf_io 2>/dev/null)
    [ -z "$io" ] && io=$(getprop persist.sys.mtkaieng.default_io 2>/dev/null)
    [ -n "$io" ] && az_set_iosched "$io"

    local limiter
    limiter=$(tr -d '\r\n ' < "/sdcard/GovThermal/freq_scale.txt" 2>/dev/null)
    if [ -n "$limiter" ] && [ "$limiter" -ge 30 ] 2>/dev/null && [ "$limiter" -le 100 ] 2>/dev/null; then
        az_apply_freq "$limiter" 0
    else
        az_apply_freq 100 0
    fi

    az_mtk_ppm_performance
    az_mtk_dvfsrc_performance
    az_gpu_performance
    az_fpsgo_on
    az_eas_off
    az_core_ctl_disable
    az_wq_performance
    az_vm_performance
    az_sched_features_performance
    az_tune_schedutil performance
    az_schedtune_performance
    az_battery_saver_disable

    az_write 1 /proc/sys/kernel/sched_energy_aware 2>/dev/null
    az_write 0 /proc/sys/kernel/split_lock_mitigate 2>/dev/null

    az_log "PERFORMANCE applied"
}

# ===========================================================================
# BALANCED PROFILE
# ===========================================================================
azenith_balanced_cpu() {
    az_log "Profile: BALANCED"

    local gov
    gov=$(getprop persist.sys.mtkaieng.custom_default_cpu_gov 2>/dev/null)
    [ -z "$gov" ] && gov=$(getprop persist.sys.mtkaieng.default_cpu_gov 2>/dev/null)
    [ -z "$gov" ] && gov="schedutil"
    az_set_governor "$gov"

    local io
    io=$(getprop persist.sys.mtkaieng.custom_balanced_io 2>/dev/null)
    [ -z "$io" ] && io=$(getprop persist.sys.mtkaieng.default_io 2>/dev/null)
    [ -n "$io" ] && az_set_iosched "$io"

    local limiter
    limiter=$(tr -d '\r\n ' < "/sdcard/GovThermal/freq_scale.txt" 2>/dev/null)
    if [ -n "$limiter" ] && [ "$limiter" -ge 30 ] 2>/dev/null && [ "$limiter" -le 100 ] 2>/dev/null; then
        az_apply_freq "$limiter" 0
    else
        az_apply_freq 100 0
    fi

    az_mtk_ppm_balance
    az_mtk_dvfsrc_balance
    az_gpu_balance
    az_eas_on
    az_wq_balance
    az_vm_balance
    az_sched_features_balance
    az_tune_schedutil balance
    az_schedtune_balance
    az_battery_saver_disable

    az_write 1 /proc/sys/kernel/sched_energy_aware 2>/dev/null
    az_write 1 /proc/sys/kernel/split_lock_mitigate 2>/dev/null

    az_log "BALANCED applied"
}

# ===========================================================================
# POWERSAVE PROFILE
# ===========================================================================
azenith_powersave_cpu() {
    az_log "Profile: POWERSAVE"

    local gov
    gov=$(getprop persist.sys.mtkaieng.custom_powersave_cpu_gov 2>/dev/null)
    [ -z "$gov" ] && gov="powersave"
    az_set_governor "$gov"

    local io
    io=$(getprop persist.sys.mtkaieng.custom_powersave_io 2>/dev/null)
    [ -z "$io" ] && io=$(getprop persist.sys.mtkaieng.default_io 2>/dev/null)
    [ -n "$io" ] && az_set_iosched "$io"

    local limiter
    limiter=$(tr -d '\r\n ' < "/sdcard/GovThermal/freq_scale.txt" 2>/dev/null)
    if [ -n "$limiter" ] && [ "$limiter" -ge 30 ] 2>/dev/null && [ "$limiter" -le 100 ] 2>/dev/null; then
        az_apply_freq "$limiter" 0
    else
        az_apply_freq 60 0
    fi

    az_mtk_ppm_powersave
    az_mtk_dvfsrc_powersave
    az_gpu_powersave
    az_fpsgo_off
    az_wq_balance
    az_vm_powersave
    az_sched_features_powersave
    az_tune_schedutil powersave
    az_battery_saver_enable

    az_write 0 /proc/sys/kernel/sched_energy_aware 2>/dev/null

    az_log "POWERSAVE applied"
}

# ===========================================================================
# ENTRY POINT
# ===========================================================================
case "$1" in
    init)         azenith_init_cpu        ;;
    performance)  azenith_performance_cpu ;;
    balanced)     azenith_balanced_cpu    ;;
    powersave)    azenith_powersave_cpu   ;;
    *)            [ -n "$1" ] || azenith_init_cpu ;;
esac
