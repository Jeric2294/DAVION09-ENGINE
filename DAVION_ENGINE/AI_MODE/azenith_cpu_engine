# Schedutil tuning (mode: performance|balance|powersave)
az_tune_schedutil() {
    local mode="${1:-balance}"
    local up_rate down_rate
    case "$mode" in
        performance) up_rate=2000;  down_rate=5000  ;;
        powersave)   up_rate=15000; down_rate=30000 ;;
        *)           up_rate=7500;  down_rate=14000 ;;
    esac
    for policy in /sys/devices/system/cpu/cpufreq/policy*; do
        [ -f "$policy/scaling_available_frequencies" ] || continue
        local avail selected num up_delay i
        avail=$(cat "$policy/scaling_available_frequencies" 2>/dev/null || echo "")
        selected=$(echo "$avail" | tr ' ' '\n' | sort -rn | head -n 6 | tr '\n' ' ' | sed 's/ $//')
        num=$(echo "$selected" | wc -w)
        up_delay=""
        i=1
        while [ "$i" -le "$num" ]; do
            up_delay="$up_delay $((50 * i))"
            i=$((i + 1))
        done
        up_delay="${up_delay# }"
        local hz_path="$policy/schedhorizon"
        local su_path="$policy/schedutil"
        if [ -d "$hz_path" ]; then
            az_write "$up_delay"  "$hz_path/up_delay"
            az_write "$selected"  "$hz_path/efficient_freq"
            az_write "$up_rate"   "$hz_path/up_rate_limit_us"
            az_write "$down_rate" "$hz_path/down_rate_limit_us"
        fi
        if [ -d "$su_path" ]; then
            az_write "$up_rate"   "$su_path/up_rate_limit_us"
            az_write "$down_rate" "$su_path/down_rate_limit_us"
        fi
    done
    az_log "Schedutil: $mode"
}

# Schedtune
az_schedtune_performance() {
    for path in /dev/stune/*; do
        az_write 30 "$path/schedtune.boost" 2>/dev/null
        az_write  1 "$path/schedtune.sched_boost_enabled" 2>/dev/null
        az_write  0 "$path/schedtune.prefer_idle" 2>/dev/null
        az_write  0 "$path/schedtune.colocate" 2>/dev/null
    done
    az_write 50 "/dev/stune/top-app/schedtune.boost" 2>/dev/null
    az_log "Schedtune: performance"
}

az_schedtune_balance() {
    for path in /dev/stune/*; do
        az_write 0 "$path/schedtune.boost" 2>/dev/null
        az_write 0 "$path/schedtune.sched_boost_enabled" 2>/dev/null
        az_write 0 "$path/schedtune.prefer_idle" 2>/dev/null
        az_write 0 "$path/schedtune.colocate" 2>/dev/null
    done
    az_write 10 "/dev/stune/top-app/schedtune.boost" 2>/dev/null
    az_log "Schedtune: balance"
}

