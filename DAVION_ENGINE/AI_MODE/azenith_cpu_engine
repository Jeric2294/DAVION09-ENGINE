az_sched_features_balance() {
    if [ -f "/sys/kernel/debug/sched_features" ]; then
        az_write "NEXT_BUDDY" /sys/kernel/debug/sched_features 2>/dev/null
        az_write "TTWU_QUEUE" /sys/kernel/debug/sched_features 2>/dev/null
    fi
    echo 500000  > /proc/sys/kernel/sched_migration_cost_ns 2>/dev/null
    echo 1000000 > /proc/sys/kernel/sched_min_granularity_ns 2>/dev/null
