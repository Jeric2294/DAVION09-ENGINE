#!/system/bin/sh
# =============================================================================
#  DAVION ENGINE — AZenith CPU Engine v2 (Bootloop-Safe)
#  CK8N / Tecno Camon 20 Pro 5G / Android 14 compatible
#  No set -e, no local in global scope, safe fallbacks everywhere
# =============================================================================

LOG_FILE="/sdcard/GovThermal/GovThermal.log"
MODDIR="/data/adb/modules/GovThermal"

az_log() {
    echo "[$(date '+%m-%d %H:%M:%S')] [azenith] $1" >> "$LOG_FILE" 2>/dev/null
}

# Safe write with chmod dance
az_write() {
    [ ! -e "$2" ] && return 0
    chmod 644 "$2" 2>/dev/null
    echo "$1" > "$2" 2>/dev/null
    chmod 444 "$2" 2>/dev/null
    return 0
}

# Safe write WITHOUT re-locking
az_write_soft() {
    [ ! -e "$2" ] && return 0
    chmod 644 "$2" 2>/dev/null
    echo "$1" > "$2" 2>/dev/null
    return 0
}

# Find closest freq in available_frequencies to a target
az_closest_freq() {
    local file="$1" target="$2" chosen=""
    if [ -f "$file" ]; then
        chosen=$(tr -s ' ' '\n' < "$file" |
            awk -v t="$target" '
                {diff = (t - $1 >= 0 ? t - $1 : $1 - t)}
                NR==1 || diff < mindiff {mindiff = diff; val=$1}
                END {print val}')
    fi
    [ -z "$chosen" ] && chosen="$target"
    echo "$chosen"
}

# Set governor on all CPUs/policies
az_set_governor() {
    local gov="$1"
    chmod 644 /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor 2>/dev/null
    echo "$gov" | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor > /dev/null 2>&1
    chmod 444 /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor 2>/dev/null
    chmod 444 /sys/devices/system/cpu/cpufreq/policy*/scaling_governor 2>/dev/null
    az_log "Governor: $gov"
}

# Set I/O scheduler
az_set_iosched() {
    local sched="$1"
    for block in sda sdb sdc mmcblk0 mmcblk1; do
        [ -e "/sys/block/$block/queue/scheduler" ] || continue
        chmod 644 "/sys/block/$block/queue/scheduler" 2>/dev/null
        echo "$sched" > "/sys/block/$block/queue/scheduler" 2>/dev/null
        chmod 444 "/sys/block/$block/queue/scheduler" 2>/dev/null
    done
    az_log "I/O scheduler: $sched"
}

# Apply freq via PPM
az_apply_ppm_freq() {
    local max_pct="${1:-100}" min_pct="${2:-0}"
    [ ! -d /proc/ppm ] && return 1
    local cluster=0
    for path in /sys/devices/system/cpu/cpufreq/policy*; do
        [ -f "$path/cpuinfo_max_freq" ] || continue
        local cpu_max cpu_min new_max new_min avail
        cpu_max=$(cat "$path/cpuinfo_max_freq" 2>/dev/null || echo 0)
        cpu_min=$(cat "$path/cpuinfo_min_freq" 2>/dev/null || echo 0)
        avail="$path/scaling_available_frequencies"
        local max_target min_target
        max_target=$((cpu_max * max_pct / 100))
        new_max=$(az_closest_freq "$avail" "$max_target")
        if [ "$min_pct" -gt 0 ] 2>/dev/null; then
            min_target=$((cpu_max * min_pct / 100))
            new_min=$(az_closest_freq "$avail" "$min_target")
        else
            new_min="$cpu_min"
        fi
        az_write "$cluster $new_max" "/proc/ppm/policy/hard_userlimit_max_cpu_freq"
        az_write "$cluster $new_min" "/proc/ppm/policy/hard_userlimit_min_cpu_freq"
        cluster=$((cluster + 1))
    done
    az_log "PPM freq: max=${max_pct}% min=${min_pct}%"
}

# Apply freq via sysfs (fallback)
az_apply_sysfs_freq() {
    local max_pct="${1:-100}" min_pct="${2:-0}"
    for path in /sys/devices/system/cpu/cpufreq/policy* /sys/devices/system/cpu/*/cpufreq; do
        [ -f "$path/cpuinfo_max_freq" ] || continue
        local cpu_max cpu_min avail new_max new_min
        cpu_max=$(cat "$path/cpuinfo_max_freq" 2>/dev/null || echo 0)
        cpu_min=$(cat "$path/cpuinfo_min_freq" 2>/dev/null || echo 0)
        avail="$path/scaling_available_frequencies"
        local max_target
        max_target=$((cpu_max * max_pct / 100))
        new_max=$(az_closest_freq "$avail" "$max_target")
        new_min="$cpu_min"
        if [ "$min_pct" -gt 0 ] 2>/dev/null; then
            local min_target
            min_target=$((cpu_max * min_pct / 100))
            new_min=$(az_closest_freq "$avail" "$min_target")
        fi
        chmod 644 "$path/scaling_max_freq" "$path/scaling_min_freq" 2>/dev/null
        echo "$cpu_max"  > "$path/scaling_max_freq" 2>/dev/null
        echo "$new_min"  > "$path/scaling_min_freq" 2>/dev/null
        echo "$new_max"  > "$path/scaling_max_freq" 2>/dev/null
    done
    az_log "Sysfs freq: max=${max_pct}% min=${min_pct}%"
}

az_apply_freq() {
    if [ -d /proc/ppm ]; then
        az_apply_ppm_freq "$@"
    else
        az_apply_sysfs_freq "$@"
    fi
}

# GPU performance (gpufreqv2 + Mali devfreq + GED)
az_gpu_performance() {
    if [ -f /proc/gpufreqv2/stack_signed_opp_table ]; then
        local max_opp
        max_opp=$(head -n1 /proc/gpufreqv2/stack_signed_opp_table 2>/dev/null | awk '{print $3}' | cut -d',' -f1)
        [ -n "$max_opp" ] && az_write_soft "$max_opp" /sys/kernel/ged/hal/custom_upbound_gpu_freq
        echo -1 > /proc/gpufreqv2/fix_target_opp_index 2>/dev/null
    fi
    for g in /sys/class/devfreq/*.mali*/governor /sys/class/devfreq/*gpu*/governor; do
        [ -f "$g" ] || continue
        local avail
        avail=$(cat "$(dirname "$g")/available_governors" 2>/dev/null || echo "")
        if echo "$avail" | grep -q "performance"; then
            az_write_soft "performance" "$g"
        elif echo "$avail" | grep -q "simple_ondemand"; then
            az_write_soft "simple_ondemand" "$g"
        fi
    done
    az_write 0 /sys/kernel/ged/hal/dcs_mode 2>/dev/null
    az_log "GPU: performance"
}

az_gpu_balance() {
    if [ -f /proc/gpufreqv2/fix_target_opp_index ]; then
        echo -1 > /proc/gpufreqv2/fix_target_opp_index 2>/dev/null
    fi
    for g in /sys/class/devfreq/*.mali*/governor /sys/class/devfreq/*gpu*/governor; do
        [ -f "$g" ] || continue
        local avail
        avail=$(cat "$(dirname "$g")/available_governors" 2>/dev/null || echo "")
        if echo "$avail" | grep -q "simple_ondemand"; then
            az_write_soft "simple_ondemand" "$g"
        fi
    done
    az_write 1 /sys/kernel/ged/hal/dcs_mode 2>/dev/null
    az_log "GPU: balance"
}

az_gpu_powersave() {
    for g in /sys/class/devfreq/*.mali*/governor /sys/class/devfreq/*gpu*/governor; do
        [ -f "$g" ] || continue
        local avail
        avail=$(cat "$(dirname "$g")/available_governors" 2>/dev/null || echo "")
        if echo "$avail" | grep -q "powersave"; then
            az_write_soft "powersave" "$g"
        elif echo "$avail" | grep -q "simple_ondemand"; then
            az_write_soft "simple_ondemand" "$g"
        fi
    done
    az_log "GPU: powersave"
}

