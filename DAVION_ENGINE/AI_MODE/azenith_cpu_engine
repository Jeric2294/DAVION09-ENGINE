# MTK PPM
az_mtk_ppm_performance() {
    [ ! -d /proc/ppm ] && return 0
    if [ -f /proc/ppm/policy_status ]; then
        for idx in $(grep -E 'FORCE_LIMIT|PWR_THRO|THERMAL|USER_LIMIT' /proc/ppm/policy_status 2>/dev/null | awk -F'[][]' '{print $2}'); do
            az_write "$idx 0" "/proc/ppm/policy_status"
        done
        for dx in $(grep -E 'SYS_BOOST' /proc/ppm/policy_status 2>/dev/null | awk -F'[][]' '{print $2}'); do
            az_write "$dx 1" "/proc/ppm/policy_status"
        done
    fi
    az_write "1" "/proc/cpufreq/cpufreq_cci_mode" 2>/dev/null
    az_write "3" "/proc/cpufreq/cpufreq_power_mode" 2>/dev/null
    az_log "PPM: performance"
}

az_mtk_ppm_balance() {
    [ ! -d /proc/ppm ] && return 0
    if [ -f /proc/ppm/policy_status ]; then
        for idx in $(grep -E 'FORCE_LIMIT|PWR_THRO|THERMAL|USER_LIMIT' /proc/ppm/policy_status 2>/dev/null | awk -F'[][]' '{print $2}'); do
            az_write "$idx 1" "/proc/ppm/policy_status"
        done
        for dx in $(grep -E 'SYS_BOOST' /proc/ppm/policy_status 2>/dev/null | awk -F'[][]' '{print $2}'); do
            az_write "$dx 0" "/proc/ppm/policy_status"
        done
    fi
    az_write "0" "/proc/cpufreq/cpufreq_cci_mode" 2>/dev/null
    az_write "1" "/proc/cpufreq/cpufreq_power_mode" 2>/dev/null
    az_log "PPM: balance"
}

az_mtk_ppm_powersave() {
    [ ! -d /proc/ppm ] && return 0
    if [ -f /proc/ppm/policy_status ]; then
        for idx in $(grep -E 'FORCE_LIMIT|PWR_THRO|THERMAL|USER_LIMIT' /proc/ppm/policy_status 2>/dev/null | awk -F'[][]' '{print $2}'); do
            az_write "$idx 1" "/proc/ppm/policy_status"
        done
        for dx in $(grep -E 'SYS_BOOST' /proc/ppm/policy_status 2>/dev/null | awk -F'[][]' '{print $2}'); do
            az_write "$dx 0" "/proc/ppm/policy_status"
        done
